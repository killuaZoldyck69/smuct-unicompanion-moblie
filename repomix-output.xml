    marginTop: 4,
  },
  divider: {
    width: 1,
    backgroundColor: colors.surfaceContainerHighest,
    marginHorizontal: spacing.stackLg,
  },
  infoColumn: {
    flex: 1,
    justifyContent: "center",
  },
  courseCode: {
    ...typography.labelMd,
    color: colors.primary,
    fontWeight: "800",
    marginBottom: 4,
  },
  courseName: {
    ...typography.bodyMd,
    color: colors.onSurface,
    fontWeight: "600",
    lineHeight: 20,
    marginBottom: 8,
  },
  roomRow: {
    flexDirection: "row",
