              />
            </View>
          </KeyboardAvoidingView>
        </SafeAreaView>
      </Modal>

      {/* --- USER PROFILE INFO MODAL --- */}
      <Modal
        visible={!!selectedProfile}
        animationType="fade"
        transparent={true}
