                    </Text>
                    {isSelected && (
                      <Feather name="check" size={20} color="#1e3a8a" />
                    )}
                  </TouchableOpacity>
                );
              }}
            />
          </View>
        </View>
      </Modal>
    </Modal>
  );
}

